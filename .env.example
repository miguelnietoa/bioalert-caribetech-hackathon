# BioAlert+ environment variables (local dev only)
# Copia este archivo a .env y completá los valores.
# En AWS, todos estos viven en SSM Parameter Store, no en .env.
# .env está en .gitignore.

# ─── Biofood Global DB (PostgreSQL) ────────────────────────────────
# Credenciales públicas del reto: https://reto.biofoodsoftware.co/
# Válidas durante el hackathon. Confirmar antes de cada sesión.
PGHOST=3.208.123.187
PGPORT=5432
PGDATABASE=biofooddb
PGUSER=hackathon_dev
PGPASSWORD=PasswordHackaton2026
PGSSLMODE=prefer

# ─── Biofood Demo Platform (para testear UX existente) ─────────────
# School admin demo
BIOFOOD_ADMIN_EMAIL=admindemocol@email.com
BIOFOOD_ADMIN_PASSWORD=admindemocol
# Parent demo
BIOFOOD_PARENT_EMAIL=padredemocol@email.com
BIOFOOD_PARENT_PASSWORD=padredemocol

# ─── Claude API (Anthropic) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_CONVERSATIONAL=claude-sonnet-4-6
CLAUDE_MODEL_BATCH=claude-haiku-4-5-20251001

# ─── Kapso (canal WhatsApp — primario) ─────────────────────────────
KAPSO_API_KEY=
KAPSO_WEBHOOK_SECRET=
KAPSO_SANDBOX_NUMBER=
# Meta phone_number_id (Kapso dashboard → sandbox, o GET .../platform/v1/whatsapp/phone_numbers)
KAPSO_PHONE_NUMBER_ID=

# ─── Demo WhatsApp E.164 (fixtures Task 12 — ver analysis/results/caso-demo.md) ─
# Si solo hay un sandbox, repetí KAPSO_SANDBOX_NUMBER en los tres o dejá solo esa variable.
DEMO_PHONE_MIGUEL=
DEMO_PHONE_ARCILA=
DEMO_PHONE_MAZA=

# ─── Twilio (canal WhatsApp — fallback) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SANDBOX_NUMBER=

# ─── AWS ───────────────────────────────────────────────────────────
# Las credenciales (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY) NO van aquí.
# Viven en ~/.aws/credentials, configuradas con `aws configure --profile biofood-hackathon`.
# Serverless Framework lee el profile desde aws-profile en serverless.yml.
#
# Onboarding completo (para Arcila y Maza): docs/aws-onboarding.md
#   - Cuenta:  642722971137 (sandbox de Miguel)
#   - Región:  us-east-1
#   - Profile: biofood-hackathon
#   - Miguel reparte la access key compartida por canal privado.
AWS_REGION=us-east-1
AWS_PROFILE=biofood-hackathon
