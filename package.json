{
  "name": "bioalert",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "deploy": "serverless deploy --stage hackathon",
    "deploy:logs": "serverless logs --tail --stage hackathon",
    "remove": "serverless remove --stage hackathon",
    "etl": "tsx scripts/etl-reto-to-rds.ts",
    "etl:shell": "bash scripts/etl-reto-to-rds.sh",
    "schema:apply": "tsx scripts/apply-schema.ts",
    "schema:apply:shell": "bash scripts/apply-schema.sh",
    "nutrition:bootstrap": "tsx scripts/bootstrap-nutrition.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "pg": "^8.13.0",
    "pg-copy-streams": "^6.0.6",
    "pg-copy-streams": "^7.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "serverless": "^4.4.18",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
