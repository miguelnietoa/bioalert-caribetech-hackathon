# Copia a .env.local para desarrollo (Vite solo expone variables VITE_*).
# Para build de producción, crea .env.production con los mismos valores.

# URL base del HTTP API que sirve /cafeteria-insights
# (Lambda lambdas/cafeteria-insights-api). NO incluye el path final.
VITE_BIOALERT_API_URL=https://c8brdpdf03.execute-api.us-east-1.amazonaws.com

# Forzar mock aunque exista API (útil para demo offline)
VITE_USE_MOCK=false

# Colegio piloto (debe coincidir con fixtures bioalert.cafeteria_admins)
VITE_SCHOOL_NIT=900000680
VITE_SCHOOL_NAME=COLEGIO DEMO 680
