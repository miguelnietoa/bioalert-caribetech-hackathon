# Copia a .env.local para desarrollo (Vite solo expone variables VITE_*)

# URL base de la API BioAlert+ (Lambda cafeteria-weekly / API Gateway)
# Ejemplo: https://xxxx.execute-api.us-east-1.amazonaws.com/dev
VITE_BIOALERT_API_URL=

# Forzar mock aunque exista API (útil para demo offline)
VITE_USE_MOCK=true

# Colegio piloto (debe coincidir con fixtures bioalert_cafeteria_admins)
VITE_SCHOOL_NIT=900123456-1
VITE_SCHOOL_NAME=DEMO COLOMBIA
